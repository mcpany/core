load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "validation",
    srcs = [
        "ip.go",
        "url.go",
        "validation.go",
    ],
    importpath = "github.com/mcpany/core/server/pkg/validation",
    visibility = ["//visibility:public"],
    deps = ["//proto/config/v1:config"],
)

go_test(
    name = "validation_test",
    srcs = [
        "ip_test.go",
        "sensitive_files_test.go",
