load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "grpc_weather_server_lib",
    srcs = ["main.go"],
    importpath = "github.com/mcpany/core/server/tests/integration/cmd/mocks/grpc_weather_server",
    visibility = ["//visibility:private"],
    deps = [
        "//proto/examples/weather/v1:weather",
