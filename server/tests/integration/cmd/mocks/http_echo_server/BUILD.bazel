load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("@rules_oci//oci:defs.bzl", "oci_image", "oci_load")
load("@rules_pkg//pkg:mappings.bzl", "pkg_files")
load("@rules_pkg//pkg:tar.bzl", "pkg_tar")

go_library(
    name = "http_echo_server_lib",
    srcs = ["main.go"],
    importpath = "github.com/mcpany/core/server/tests/integration/cmd/mocks/http_echo_server",
    visibility = ["//visibility:private"],
    deps = ["//server/pkg/consts"],
)

go_binary(
    name = "http_echo_server",
    embed = [":http_echo_server_lib"],
    visibility = ["//visibility:public"],
)

pkg_files(
    name = "http_echo_server_binary_files",
    srcs = [":http_echo_server"],
    prefix = "/app",
)

pkg_tar(
    name = "http_echo_server_layer",
    srcs = [":http_echo_server_binary_files"],
)

oci_image(
    name = "http_echo_server_image",
    base = "@debian_bookworm_slim",
    entrypoint = ["/app/http_echo_server"],
    exposed_ports = ["8080/tcp"],
    tars = [":http_echo_server_layer"],
)

oci_load(
    name = "http_echo_server_tarball",
    image = ":http_echo_server_image",
    repo_tags = [
        "mcpany/http-echo-server:latest",
        "mcpany/http-echo-server:1.0.0",
    ],
    visibility = ["//visibility:public"],
)
