FROM mirror.gcr.io/library/python:3.11-slim

# Change to a directory where overlayfs invalid argument errors won't trigger (avoid /app)
COPY timeserver_patch/service /service
WORKDIR /service

RUN pip install --no-cache-dir -r requirements.txt

CMD ["python", "-u", "/service/main.py", "--mcp-stdio"]
