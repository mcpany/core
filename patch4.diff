--- server/docker/Dockerfile.server
+++ server/docker/Dockerfile.server
@@ -37,7 +37,7 @@
 ARG TARGETOS
 ARG TARGETARCH
 # CGO_ENABLED=1 is required for go-sqlite3
-RUN --mount=type=cache,target=/root/.cache/go-build \
+RUN \
     --mount=type=cache,target=/go/pkg/mod \
