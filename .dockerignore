# Top-level directories to exclude (reduce context size)
server/
k8s/
docs/
marketplace/
build/
.git/
.github/
node_modules/

# Files to exclude
.DS_Store
coverage/
*.log
.gemini/
.audits/
.audit/
lint_report.*
.last-run
**/.last-run.json
client_info.json
oauth_env.sh
AUDIT_REPORT.md

# UI specific excludes (retained from original logic but explicit here)
ui/node_modules
ui/.next
ui/test-results
ui/playwright-report
ui/coverage

# Proto specific excludes
# We MUST NOT exclude proto/ unless it's node_modules
proto/node_modules

# Note: We do NOT start with '*' to ensure all other files (like proto/**/*.ts)
# are included by default unless explicitly excluded above.
